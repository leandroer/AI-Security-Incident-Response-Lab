// Detection: AGENT03 - Agent Data Exfiltration
OfficeActivity
| where TimeGenerated > ago(24h)
| where Workload in ("SharePoint", "OneDrive", "MicrosoftTeams", "Exchange")
| summarize ResourceAccessCount=count(), Operations=make_set(Operation, 50), Sites=make_set(Site_Url, 25) by UserId, bin(TimeGenerated, 15m)
| where ResourceAccessCount > 500
| extend DetectionName = "AGENT03 - Potential Agent Data Exfiltration", Severity = "Critical"
| project TimeGenerated, DetectionName, Severity, UserId, ResourceAccessCount, Operations, Sites
